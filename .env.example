# Get these from https://console.upstash.com after creating a Redis database
# These are SERVER-SIDE only (no VITE_ prefix) — never exposed to the browser
UPSTASH_URL=https://your-database.upstash.io
UPSTASH_TOKEN=your-read-write-token

# Get this from https://dashboard.privy.io after creating an app (App ID only — never paste the App Secret here)
VITE_PRIVY_APP_ID=your-privy-app-id
